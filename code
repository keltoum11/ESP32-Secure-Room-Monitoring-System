void handleSetLED() {
  String led = server.arg("led");
  String action = server.arg("action");
  String value = server.arg("value");
  
  Serial.println("LED Control: " + led + " - " + action);
  
  if (led == "lumi") {
    if (action == "on") {
      lumiState = true;
      ledcWrite(lumiChannel, 255);
    } else if (action == "off") {
      lumiState = false;
      ledcWrite(lumiChannel, 0);
    } else if (action == "toggle") {
      lumiState = !lumiState;
      ledcWrite(lumiChannel, lumiState ? 255 : 0);
    } else if (action == "brightness") {
      int brightness = value.toInt();
      ledcWrite(lumiChannel, brightness);
      lumiState = (brightness > 0);
    }
  } 
  else if (led == "clem") {
    if (action == "on") {
      clemState = true;
      ledcWrite(clemChannel, 255);
    } else if (action == "off") {
      clemState = false;
      ledcWrite(clemChannel, 0);
    } else if (action == "toggle") {
      clemState = !clemState;
      ledcWrite(clemChannel, clemState ? 255 : 0);
    } else if (action == "brightness") {
      int brightness = value.toInt();
      ledcWrite(clemChannel, brightness);
      clemState = (brightness > 0);
    }
  }
  
  server.send(200, "text/plain", "LED " + led + " " + action + " OK");
}

void handleLogs() {
  String json = "[";
  for (int i = 0; i < logCount; i++) {
    json += "{";
    json += "\"time\":\"" + accessLogs[i].time + "\",";
    json += "\"name\":\"" + accessLogs[i].name + "\",";
    json += "\"uid\":\"" + accessLogs[i].uid + "\",";
    json += "\"status\":\"" + accessLogs[i].status + "\"";
    json += "}";
    if (i < logCount - 1) json += ",";
  }
  json += "]";
  
  server.send(200, "application/json", json);
}

void handleClearLogs() {
  logCount = 0;
  server.send(200, "text/plain", "Logs cleared");
}

