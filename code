// Déclaration des pins
#define LED_red 16      // LED rouge - accès refusé
#define LED_orange 17   // LED orange - accès accordé
#define LED_lumi 26     // LED 26 - luminosité
#define LED_clem 27     // LED 27 - clematisation
#define DOOR_BUTTON 4

// Variables pour LEDs
bool lumiState = false;   // État LED luminosité
bool clemState = false;   // État LED clematisation

// Configuration PWM pour ESP32
const int freq = 5000;
const int lumiChannel = 0;
const int clemChannel = 1;
const int resolution = 8;

// Stockage logs RFID
struct AccessLog {
  String uid;
  String name;
  String time;
  String status;
};

AccessLog accessLogs[50];
int logCount = 0;

struct Employee {
