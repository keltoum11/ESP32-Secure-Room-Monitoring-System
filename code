void setup() {
  // Configuration pins
  pinMode(LED_red, OUTPUT);
  pinMode(LED_orange, OUTPUT);
  pinMode(DOOR_BUTTON, INPUT);
  
  // Configuration PWM pour LEDs
  ledcSetup(lumiChannel, freq, resolution);
  ledcSetup(clemChannel, freq, resolution);
  ledcAttachPin(LED_lumi, lumiChannel);
  ledcAttachPin(LED_clem, clemChannel);
  
  // Initialisation LEDs
  digitalWrite(LED_red, LOW);
  digitalWrite(LED_orange, LOW);
  ledcWrite(lumiChannel, 0);
  ledcWrite(clemChannel, 0);
  
  // Initialisation Serial
  Serial.begin(115200);
  
  // Initialisation LCD
  Wire.begin(21, 22);  
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("RFID Check-in");
  lcd.setCursor(0, 1);
  lcd.print("System Ready");
  
  // Initialisation RFID
  mfrc522.PCD_Init();
  Serial.println("RFID Ready");
  
  // Connexion WiFi
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Connecting WiFi");
  
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  
  Serial.println("");
  Serial.println("WiFi connected!");
  Serial.print("IP: ");
  Serial.println(WiFi.localIP());
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("WiFi Connected");
  lcd.setCursor(0, 1);
  lcd.print(WiFi.localIP());
  delay(2000);
  
  // Configuration Web Server
  server.on("/", handleRoot);            // Page principale
  server.on("/logs", handleLogs);        // Logs en JSON
  server.on("/clear", handleClearLogs);  // Effacer logs
  server.on("/ledcontrol", handleLEDControl);  // Page contrôle LEDs
  server.on("/setled", handleSetLED);    // API contrôle LED
  
  server.begin();
  Serial.println("Web Server Started");
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Scan your card");
}

void loop() {
  server.handleClient();  // Gérer requêtes web
  
  // Lecture RFID
  if (!mfrc522.PICC_IsNewCardPresent()) {
    return;
  }
  
  if (!mfrc522.PICC_ReadCardSerial()) {
    return;
  }
  
  String uid = getUID();
  String checkInTime = getTime();
  String employeeName = findEmployee(uid);
  bool hasAccess = checkAccess(employeeName);
  
  // Enregistrer log
  if (logCount < 50) {
    accessLogs[logCount].uid = uid;
    accessLogs[logCount].name = employeeName;
    accessLogs[logCount].time = checkInTime;
    accessLogs[logCount].status = hasAccess ? "GRANTED" : "DENIED";
    logCount++;
  }
  
  // Affichage Serial
  Serial.println("====================");
  Serial.println("Card Detected!");
  Serial.println("UID: " + uid);
  Serial.println("Employee: " + employeeName);
  Serial.println("Access: " + String(hasAccess ? "GRANTED" : "DENIED"));
  Serial.println("Time: " + checkInTime);
  Serial.println("Web: " + WiFi.localIP());
  Serial.println("====================");
  
  // Contrôle LEDs et LCD
  if (employeeName == "Unknown") {
    digitalWrite(LED_red, HIGH);
    digitalWrite(LED_orange, LOW);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("UNKNOWN REJECTED!");
    lcd.setCursor(0, 1);
    lcd.print("Time: " + checkInTime);
    delay(5000);
    digitalWrite(LED_red, LOW);
  } else if (!hasAccess) {
    digitalWrite(LED_red, HIGH);
    digitalWrite(LED_orange, LOW);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(employeeName + " REJECTED");
    lcd.setCursor(0, 1);
    lcd.print("Time: " + checkInTime);
    delay(5000);
    digitalWrite(LED_red, LOW);
  } else {
    digitalWrite(LED_red, LOW);
    digitalWrite(LED_orange, HIGH);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(employeeName + " ACCEPTED");
    lcd.setCursor(0, 1);
    lcd.print("open the door");
    
    while (digitalRead(DOOR_BUTTON) == LOW) {
      delay(10);
    }
    
    digitalWrite(LED_orange, LOW);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(employeeName + " ACCEPTED");
    lcd.setCursor(0, 1);
    lcd.print("Time: " + checkInTime);
    delay(5000);
  }
  
  mfrc522.PICC_HaltA();
  mfrc522.PCD_StopCrypto1();  
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Scan your card");
}

